# ====================================================================
# [SimpleM] 백엔드 환경 변수 설정 (.env.example)
# 실제 사용 시 .env 파일로 복사하여 비밀번호 및 서버 주소를 수정하세요.
# ====================================================================

# 1. PostgreSQL 데이터베이스 연결 주소 (psycopg2 호환)
# 형식: postgresql://[사용자명]:[비밀번호]@[서버주소]:[포트]/[데이터베이스명]
#
# [로컬 개발]
DATABASE_URL=postgresql://postgres:simplem@localhost:5432/simpleM
#
# [Neon 등 서버리스 Postgres로 배포] — 아래처럼 ?sslmode=require 를 반드시 붙이고,
# 가능하면 '-pooler'가 붙은 pooler 엔드포인트를 사용한다. (배포 서버의 환경변수에 넣을 것)
# DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
# 서버리스 cold start 대비 연결 타임아웃(초). Neon은 10초 이상 권장.
DB_CONNECT_TIMEOUT=10
# 커넥션 풀 크기 (무료 티어 동시 연결 제한이 있으면 낮춰서 3~5).
DB_POOL_SIZE=5

# 1-2. JWT 서명 키 (필수) — 설정하지 않으면 소스에 박힌 공개 기본값으로 폴백되어 누구나 토큰을 위조할 수 있다.
# 각자 고유한 값으로 생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_generate_with_secrets_token_urlsafe_48

# 1-3. 관리자 콘솔(admin_web) 로그인 — 허용 관리자 이메일(콤마 구분)과 콘솔 비밀번호
# ADMIN_PASSWORD가 비어 있으면 관리자 로그인이 비활성화된다.
ADMIN_EMAILS=admin@simplem.com
ADMIN_PASSWORD=change_me_admin_console_password

# ─────────────────────────────────────────────
# [필수 — 챗봇] Google Gemini (챗봇 두뇌·리포트 조언)
# aistudio.google.com 에서 API 키 발급
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# ─────────────────────────────────────────────
# [기능별 외부 API — 없으면 해당 기능만 비활성/에러]
# ─────────────────────────────────────────────
# 네이버 오픈API (가격 비교 검색) / NCP 지도 (지오코딩)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NCP_MAPS_CLIENT_ID=
NCP_MAPS_CLIENT_SECRET=
# 챗봇 웹 검색 (tavily.com)
TAVILY_API_KEY=
# 서울 열린데이터광장 (상권/유동인구 — 판매 예측 보조)
SEOUL_OPENAPI_KEY=
# Square POS 동기화 (developer.squareup.com)
SQUARE_APP_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
# Firebase 인증 (모바일 소셜 로그인 토큰 검증)
FIREBASE_PROJECT_ID=

# ─────────────────────────────────────────────
# [선택] LangSmith 트레이싱 (비우면 비활성)
# ─────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=simplem

# ─────────────────────────────────────────────
# [OCR] 백엔드 선택: llamacpp_vlm(기본) / qwen_vlm / ollama_vlm
# llamacpp_vlm: 로컬 llama.cpp 서버 필요 (AUTOSTART=1이면 자동 기동)
# qwen_vlm: torch/transformers/peft 별도 설치 필요 (requirements 미포함)
# ─────────────────────────────────────────────
OCR_BACKEND=llamacpp_vlm
LLAMACPP_BASE_URL=http://localhost:8089
LLAMACPP_AUTOSTART=1
# LLAMACPP_SERVER_EXE=vlm_finetune/tools_bin/llama-server.exe
# LLAMACPP_MODEL_GGUF=vlm_finetune/output/qwen35-08b-ocr-v2-q8.gguf
# LLAMACPP_MMPROJ_GGUF=vlm_finetune/output/mmproj-qwen35-08b.gguf

# ─────────────────────────────────────────────
# [선택] 서비스 실행 환경 (development / production)
# ─────────────────────────────────────────────
ENV=development
