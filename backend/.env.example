# SimpleM 백엔드 환경변수
#
# 사용법: 이 파일을 .env로 복사한 뒤 실제 값을 채우세요. (.env는 gitignore되어 커밋되지 않습니다)
#   copy .env.example .env
# 실제 키 값은 팀 채팅으로 공유받으세요 — 이 파일에는 절대 실제 키를 적지 마세요.

# ─────────────────────────────────────────────
# [필수] 데이터베이스 — 팀 공유 PostgreSQL
# 형식: postgresql://계정:비밀번호@호스트:5432/DB이름
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/simpleM

# ─────────────────────────────────────────────
# [필수] 인증 (JWT)
# 비워두면 코드의 기본값을 쓰지만, 배포 시엔 반드시 팀 공통 값으로 설정
# ─────────────────────────────────────────────
SECRET_KEY=your-jwt-secret-key

# ─────────────────────────────────────────────
# [필수 — 챗봇] Google Gemini (챗봇 두뇌 모델)
# aistudio.google.com 에서 API 키 발급
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# ─────────────────────────────────────────────
# [선택] OCR 동작 옵션 — 생략 시 괄호 안 기본값 사용
# ─────────────────────────────────────────────
# OCR 백엔드: qwen_vlm(기본, 파인튜닝 로컬 VLM) 또는 ollama_vlm(완전 오프라인)
#OCR_BACKEND=qwen_vlm
# 전송 전 이미지 축소 기준 px (1280)
#OCR_MAX_IMAGE_SIDE=1280
# 영수증 원본 저장 폴더 (backend/uploads/ocr)
#OCR_UPLOAD_DIR=

# ─────────────────────────────────────────────
# [선택] Qwen VLM — 기본 OCR 백엔드(qwen_vlm) 동작 옵션
# ─────────────────────────────────────────────
# 4bit는 VRAM을 아끼는 대신 매 토큰 역양자화 때문에 2배 느리다.
# RTX 5060(8GB) 실측: 4bit 25초 vs bf16 14초, bf16 피크 VRAM 4.5GB로 여유 있음.
# → 기본(bf16)을 그대로 쓰고, VRAM이 더 좁은 GPU에서만 1로 켤 것.
#QWEN_VLM_LOAD_4BIT=0
# LoRA 어댑터를 베이스에 병합해 매 토큰 추가 연산 제거 (기본 1, 4bit일 땐 자동 무시)
#QWEN_VLM_MERGE_ADAPTER=1
# 추론 해상도 — 반드시 학습(train.py --max-side, 기본 1024)과 일치시킬 것.
# 1280으로 넣으면 train/serve skew로 정확도↓, vision 토큰↑로 속도도 느려진다.
#QWEN_VLM_MAX_IMAGE_SIDE=1024
# flash-attn 설치 시 prefill 단축: QWEN_VLM_ATTN=flash_attention_2 (기본 sdpa)
#QWEN_VLM_ATTN=sdpa
#QWEN_VLM_MAX_NEW_TOKENS=1024

# ─────────────────────────────────────────────
# [선택] Ollama — OCR_BACKEND=ollama_vlm(오프라인 모드)일 때만 필요
# 주의: gemma4:latest(8B)는 Windows에서 이미지 인식 버그가 있으므로 12b 사용
# ─────────────────────────────────────────────
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_OCR_MODEL=gemma4:12b
#OLLAMA_OCR_TIMEOUT=300
#OLLAMA_KEEP_ALIVE=30m

# ─────────────────────────────────────────────
# [선택] Square POS 연동 (core/config.py)
# ─────────────────────────────────────────────
#SQUARE_APP_ID=
#SQUARE_ACCESS_TOKEN=
#SQUARE_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────
# [선택] Firebase (core/auth.py)
# ─────────────────────────────────────────────
#FIREBASE_PROJECT_ID=simplem-app

# ─────────────────────────────────────────────
# [선택] LangSmith — 챗봇 트레이싱/분석 (키만 넣으면 자동 활성화)
# smith.langchain.com > Settings > API Keys 에서 발급 (lsv2_...)
# ─────────────────────────────────────────────
#LANGSMITH_API_KEY=
#LANGSMITH_PROJECT=simplem-chatbot
