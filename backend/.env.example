# ====================================================================
# [SimpleM] 백엔드 환경 변수 설정 (.env.example)
# 실제 사용 시 .env 파일로 복사하여 비밀번호 및 서버 주소를 수정하세요.
# ====================================================================

# 1. PostgreSQL 데이터베이스 연결 주소 (psycopg2 호환)
# 형식: postgresql://[사용자명]:[비밀번호]@[서버주소]:[포트]/[데이터베이스명]
#
# [로컬 개발]
DATABASE_URL=postgresql://postgres:simplem@localhost:5432/simpleM
#
# [Neon 등 서버리스 Postgres로 배포] — 아래처럼 ?sslmode=require 를 반드시 붙이고,
# 가능하면 '-pooler'가 붙은 pooler 엔드포인트를 사용한다. (배포 서버의 환경변수에 넣을 것)
# DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
# 서버리스 cold start 대비 연결 타임아웃(초). Neon은 10초 이상 권장.
DB_CONNECT_TIMEOUT=10
# 커넥션 풀 크기 (무료 티어 동시 연결 제한이 있으면 낮춰서 3~5).
DB_POOL_SIZE=5

# 1-2. JWT 서명 키 (필수) — 설정하지 않으면 소스에 박힌 공개 기본값으로 폴백되어 누구나 토큰을 위조할 수 있다.
# 각자 고유한 값으로 생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_generate_with_secrets_token_urlsafe_48

# 1-3. 관리자 콘솔(admin_web) 로그인 — 허용 관리자 이메일(콤마 구분)과 콘솔 비밀번호
# ADMIN_PASSWORD가 비어 있으면 관리자 로그인이 비활성화된다.
ADMIN_EMAILS=admin@simplem.com
ADMIN_PASSWORD=change_me_admin_console_password

# 2. LLM API 키 (챗봇 RAG 용도)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ─────────────────────────────────────────────
# [필수 — 챗봇] Google Gemini (챗봇 두뇌 모델)
# aistudio.google.com 에서 API 키 발급
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# ─────────────────────────────────────────────
# [선택] 서비스 실행 환경 (development / production)
# ─────────────────────────────────────────────
ENV=development

