# SimpleM 백엔드 환경변수
#
# 사용법: 이 파일을 .env로 복사한 뒤 실제 값을 채우세요. (.env는 gitignore되어 커밋되지 않습니다)
#   copy .env.example .env
# 실제 키 값은 팀 채팅으로 공유받으세요 — 이 파일에는 절대 실제 키를 적지 마세요.

# ─────────────────────────────────────────────
# [필수] 데이터베이스 — 팀 공유 PostgreSQL
# 형식: postgresql://계정:비밀번호@호스트:5432/DB이름
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/simpleM

# ─────────────────────────────────────────────
# [필수] 인증 (JWT)
# 비워두면 코드의 기본값을 쓰지만, 배포 시엔 반드시 팀 공통 값으로 설정
# ─────────────────────────────────────────────
SECRET_KEY=your-jwt-secret-key

# ─────────────────────────────────────────────
# [필수 — OCR 기능] 네이버 CLOVA OCR
# NCP 콘솔 > CLOVA OCR 도메인에서 발급.
# INVOKE_URL은 반드시 APIGW 공개 주소(https://xxxx.apigw.ntruss.com/custom/v1/.../general)
#   — clovaocr-api-kr.ncloud.com 형태는 내부망 전용이라 연결 안 됨
# 무료 한도 월 100건 (사용량은 매 분석 응답의 clova_usage로 표시됨)
# ─────────────────────────────────────────────
CLOVA_OCR_INVOKE_URL=https://xxxx.apigw.ntruss.com/custom/v1/xxxxx/xxxxxxxx/general
CLOVA_OCR_SECRET=your-clova-secret

# ─────────────────────────────────────────────
# [필수 — OCR 기능] Google Gemini (OCR 텍스트 구조화)
# aistudio.google.com 에서 API 키 발급
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# ─────────────────────────────────────────────
# [선택] OCR 동작 옵션 — 생략 시 괄호 안 기본값 사용
# ─────────────────────────────────────────────
# OCR 백엔드: clova_gemini(기본) 또는 ollama_vlm(완전 오프라인)
#OCR_BACKEND=clova_gemini
# CLOVA 무료 한도 횟수 (100)
#CLOVA_FREE_LIMIT=100
# 사용량 집계 파일 경로 (backend/uploads/clova_usage.json)
#CLOVA_USAGE_FILE=
# 전송 전 이미지 축소 기준 px (1280, CLOVA 경로는 내부적으로 1920 사용)
#OCR_MAX_IMAGE_SIDE=1280
# 영수증 원본 저장 폴더 (backend/uploads/ocr)
#OCR_UPLOAD_DIR=

# ─────────────────────────────────────────────
# [선택] Ollama — OCR_BACKEND=ollama_vlm(오프라인 모드)일 때만 필요
# 주의: gemma4:latest(8B)는 Windows에서 이미지 인식 버그가 있으므로 12b 사용
# ─────────────────────────────────────────────
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_OCR_MODEL=gemma4:12b
#OLLAMA_OCR_TIMEOUT=300
#OLLAMA_KEEP_ALIVE=30m

# ─────────────────────────────────────────────
# [선택] Square POS 연동 (core/config.py)
# ─────────────────────────────────────────────
#SQUARE_APP_ID=
#SQUARE_ACCESS_TOKEN=
#SQUARE_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────
# [선택] Firebase (core/auth.py)
# ─────────────────────────────────────────────
#FIREBASE_PROJECT_ID=simplem-app
