# ====================================================================
# SimpleM 운영 환경 변수 — 서버에서 .env.production 으로 복사해 값 채우기
# (docker-compose.prod.yml의 api 서비스가 env_file로 읽는다)
# 커밋 금지: 실제 값이 들어간 .env.production은 절대 git에 올리지 말 것
# ====================================================================

# HTTPS 도메인 (caddy 인증서 발급 대상) — compose가 직접 읽는다
API_DOMAIN=api.example.com

# PostgreSQL — Neon 클라우드 (backend/.env의 실제 값 복사)
DATABASE_URL=postgresql://neondb_owner:...@ep-....neon.tech/neondb?sslmode=require&channel_binding=require

# JWT 서명 키 — 개발 키 재사용 금지, 새로 생성:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Google Gemini (챗봇 두뇌·리포트 조언)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# 네이버/NCP (지오코딩·가격 검색)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NCP_MAPS_CLIENT_ID=
NCP_MAPS_CLIENT_SECRET=

# 웹 검색 (챗봇 도구)
TAVILY_API_KEY=

FIREBASE_PROJECT_ID=simplem-72f8d

# [선택] LangSmith 트레이싱 — 비우면 비활성
LANGSMITH_API_KEY=
