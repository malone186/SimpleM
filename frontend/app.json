{
  "expo": {
    "name": "브루노트",
    "slug": "frontend",
    "scheme": "simplem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brew_icon_cutout.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.simplem.brewnote"
    },
    "android": {
      "package": "com.simplem.brewnote",
      "adaptiveIcon": {
        "backgroundColor": "#FBEFDD",
        "foregroundImage": "./assets/brew_icon_cutout.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/brew_icon_cutout.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "bluetoothAlwaysPermission": "매장 센서(무게·온도·RFID 허브)를 찾기 위해 블루투스를 사용합니다."
        }
      ]
    ]
  }
}
