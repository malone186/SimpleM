# 백엔드 API 주소 설정
#
# 기본값은 http://localhost:8000 — 내 컴퓨터에서 백엔드(uvicorn)를 직접 띄울 때는 아무 설정 없이 동작한다.
#
# 백엔드가 다른 컴퓨터(팀원 노트북 등)에서 돌고 있으면:
#   1. 이 파일을 .env.local 이라는 이름으로 복사한다 (.env.local은 gitignore되어 커밋되지 않음)
#   2. 아래 주소를 백엔드 컴퓨터의 IP로 바꾼다
#   3. Expo 개발 서버를 재시작한다 (환경변수는 재시작해야 반영됨)
#
# 백엔드 컴퓨터 쪽 준비물:
#   - uvicorn을 --host 0.0.0.0 옵션으로 실행 (localhost로만 열면 외부에서 접속 불가)
#   - Windows 방화벽에서 8000 포트 인바운드 허용

EXPO_PUBLIC_API_BASE_URL=http://192.168.0.10:8000

# 네이버 맵 클라이언트 ID (NCP Web Dynamic Map API Client ID)
EXPO_PUBLIC_NAVER_CLIENT_ID=6amak4awt7

